#!/bin/bash

# 중복 코드 정리 검증 스크립트 (수정본)
# 작성일: 2025-01-06
# 목적: 중복 코드 정리 작업 효과 측정

echo "======================================"
echo "📊 중복 코드 정리 효과 검증"
echo "======================================"

# 색상 정의
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# 프로젝트 루트 확인
if [ ! -f "pubspec.yaml" ]; then
    echo -e "${RED}❌ Flutter 프로젝트 루트에서 실행해주세요.${NC}"
    exit 1
fi

echo -e "\n${CYAN}═══════════════════════════════════════${NC}"
echo -e "${YELLOW}📋 Step 1: 중복 코드 현황 분석${NC}"
echo -e "${CYAN}═══════════════════════════════════════${NC}"

# 전체 Dart 파일 수
TOTAL_FILES=$(find lib -name "*.dart" -type f | wc -l)
echo -e "\n전체 Dart 파일 수: ${BLUE}$TOTAL_FILES${NC}개"

# 전체 코드 라인 수
TOTAL_LINES=$(find lib -name "*.dart" -type f -exec wc -l {} + | tail -1 | awk '{print $1}')
echo -e "전체 코드 라인 수: ${BLUE}$TOTAL_LINES${NC}줄"

echo -e "\n${CYAN}═══════════════════════════════════════${NC}"
echo -e "${YELLOW}📋 Step 2: Import 중복 분석${NC}"
echo -e "${CYAN}═══════════════════════════════════════${NC}"

# 가장 많이 사용되는 import TOP 10
echo -e "\n${GREEN}가장 많이 중복된 import (TOP 10):${NC}"
find lib -name "*.dart" -type f -exec grep "^import " {} \; | \
    sort | uniq -c | sort -rn | head -10 | \
    awk '{printf "  %3d회: %s\n", $1, substr($0, index($0,$2))}'

# AppLogger import 횟수
APPLOGGER_COUNT=$(grep -r "import.*app_logger" lib/ --include="*.dart" | wc -l)
echo -e "\nAppLogger import 횟수: ${YELLOW}$APPLOGGER_COUNT${NC}회"

# 공통 import 파일 사용 여부 확인
if [ -f "lib/core/utils/common_imports.dart" ]; then
    COMMON_IMPORT_USAGE=$(grep -r "import.*common_imports" lib/ --include="*.dart" | wc -l)
    echo -e "${GREEN}✅ common_imports.dart 사용: $COMMON_IMPORT_USAGE개 파일${NC}"
    
    # 예상 절감 import 라인
    SAVED_IMPORTS=$((APPLOGGER_COUNT * 3))
    echo -e "예상 import 라인 절감: ${GREEN}약 $SAVED_IMPORTS줄${NC}"
else
    echo -e "${YELLOW}⚠️  common_imports.dart 미생성${NC}"
fi

echo -e "\n${CYAN}═══════════════════════════════════════${NC}"
echo -e "${YELLOW}📋 Step 3: 다이얼로그 패턴 분석${NC}"
echo -e "${CYAN}═══════════════════════════════════════${NC}"

# showDialog 사용 통계
SHOW_DIALOG_COUNT=$(grep -r "showDialog" lib/ --include="*.dart" | wc -l)
echo -e "\nshowDialog 사용 횟수: ${YELLOW}$SHOW_DIALOG_COUNT${NC}회"

# AlertDialog 사용 통계
ALERT_DIALOG_COUNT=$(grep -r "AlertDialog" lib/ --include="*.dart" | wc -l)
echo -e "AlertDialog 사용 횟수: ${YELLOW}$ALERT_DIALOG_COUNT${NC}회"

# Navigator.pop 패턴
NAV_POP_COUNT=$(grep -r "Navigator.of(context).pop()" lib/ --include="*.dart" | wc -l)
echo -e "Navigator.pop() 사용 횟수: ${YELLOW}$NAV_POP_COUNT${NC}회"

# DialogUtils 사용 확인
if [ -f "lib/core/utils/dialog_utils.dart" ]; then
    DIALOG_UTILS_USAGE=$(grep -r "DialogUtils\." lib/ --include="*.dart" | wc -l)
    echo -e "${GREEN}✅ DialogUtils 사용: $DIALOG_UTILS_USAGE회${NC}"
    
    # 예상 코드 절감
    AVG_DIALOG_LINES=15
    SAVED_DIALOG_LINES=$((SHOW_DIALOG_COUNT * AVG_DIALOG_LINES / 2))
    echo -e "예상 다이얼로그 코드 절감: ${GREEN}약 $SAVED_DIALOG_LINES줄${NC}"
else
    echo -e "${YELLOW}⚠️  DialogUtils 미생성${NC}"
fi

echo -e "\n${CYAN}═══════════════════════════════════════${NC}"
echo -e "${YELLOW}📋 Step 4: 권한 관리 중복 분석${NC}"
echo -e "${CYAN}═══════════════════════════════════════${NC}"

# Geolocator 권한 요청 패턴
GEO_PERMISSION_COUNT=$(grep -r "Geolocator.checkPermission\|Geolocator.requestPermission" lib/ --include="*.dart" | wc -l)
echo -e "\nGeolocator 권한 체크: ${YELLOW}$GEO_PERMISSION_COUNT${NC}회"

# Firebase 권한 요청 패턴
FCM_PERMISSION_COUNT=$(grep -r "requestPermission\|getNotificationSettings" lib/ --include="*.dart" | wc -l)
echo -e "Firebase 알림 권한 체크: ${YELLOW}$FCM_PERMISSION_COUNT${NC}회"

# openAppSettings 호출
OPEN_SETTINGS_COUNT=$(grep -r "openAppSettings\|openLocationSettings" lib/ --include="*.dart" | wc -l)
echo -e "설정 열기 호출: ${YELLOW}$OPEN_SETTINGS_COUNT${NC}회"

# UnifiedPermissionManager 사용 확인
if [ -f "lib/core/utils/unified_permission_manager.dart" ]; then
    UNIFIED_USAGE=$(grep -r "UnifiedPermissionManager\." lib/ --include="*.dart" | wc -l)
    echo -e "${GREEN}✅ UnifiedPermissionManager 사용: $UNIFIED_USAGE회${NC}"
else
    echo -e "${YELLOW}⚠️  UnifiedPermissionManager 미생성${NC}"
fi

echo -e "\n${CYAN}═══════════════════════════════════════${NC}"
echo -e "${YELLOW}📋 Step 5: 중복 함수 패턴 분석${NC}"
echo -e "${CYAN}═══════════════════════════════════════${NC}"

# 유사한 함수명 찾기
echo -e "\n${GREEN}동일한 함수명 (2회 이상):${NC}"
grep -h "^[[:space:]]*Future<.*>\|^[[:space:]]*void\|^[[:space:]]*Widget" lib/**/*.dart 2>/dev/null | \
    sed 's/^[[:space:]]*//' | \
    sed 's/{.*//' | \
    sort | uniq -c | sort -rn | \
    awk '$1 > 1 {printf "  %2d회: %s\n", $1, substr($0, index($0,$2))}' | \
    head -10

echo -e "\n${CYAN}═══════════════════════════════════════${NC}"
echo -e "${YELLOW}📋 Step 6: 코드 품질 메트릭${NC}"
echo -e "${CYAN}═══════════════════════════════════════${NC}"

# 평균 파일 크기
AVG_FILE_SIZE=$((TOTAL_LINES / TOTAL_FILES))
echo -e "\n평균 파일 크기: ${BLUE}$AVG_FILE_SIZE${NC}줄"

# 500줄 이상의 큰 파일
LARGE_FILES=$(find lib -name "*.dart" -type f -exec wc -l {} \; | awk '$1 > 500 {print $2}' | wc -l)
echo -e "500줄 이상 파일: ${YELLOW}$LARGE_FILES${NC}개"

# 1000줄 이상의 매우 큰 파일
VERY_LARGE_FILES=$(find lib -name "*.dart" -type f -exec wc -l {} \; | awk '$1 > 1000 {print $2}' | wc -l)
if [ $VERY_LARGE_FILES -gt 0 ]; then
    echo -e "${RED}1000줄 이상 파일: $VERY_LARGE_FILES개 (분할 권장)${NC}"
    echo -e "\n${YELLOW}1000줄 이상 파일 목록:${NC}"
    find lib -name "*.dart" -type f -exec wc -l {} \; | awk '$1 > 1000 {printf "  • %s (%d줄)\n", $2, $1}'
fi

echo -e "\n${CYAN}═══════════════════════════════════════${NC}"
echo -e "${YELLOW}📋 Step 7: 예상 개선 효과${NC}"
echo -e "${CYAN}═══════════════════════════════════════${NC}"

# 총 예상 절감 라인 (수정된 부분)
TOTAL_IMPORT_SAVINGS=$((APPLOGGER_COUNT * 3))
TOTAL_DIALOG_SAVINGS=$((SHOW_DIALOG_COUNT * 10))
TOTAL_PERMISSION_SAVINGS=$(((GEO_PERMISSION_COUNT + FCM_PERMISSION_COUNT) * 20))
TOTAL_SAVINGS=$((TOTAL_IMPORT_SAVINGS + TOTAL_DIALOG_SAVINGS + TOTAL_PERMISSION_SAVINGS))

echo -e "\n${GREEN}예상 코드 절감:${NC}"
echo -e "  • Import 정리: 약 ${BLUE}$TOTAL_IMPORT_SAVINGS${NC}줄"
echo -e "  • 다이얼로그 통합: 약 ${BLUE}$TOTAL_DIALOG_SAVINGS${NC}줄"
echo -e "  • 권한 관리 통합: 약 ${BLUE}$TOTAL_PERMISSION_SAVINGS${NC}줄"
echo -e "  ─────────────────────────"
echo -e "  ${GREEN}총 예상 절감: 약 $TOTAL_SAVINGS줄${NC}"

if [ $TOTAL_LINES -gt 0 ]; then
    REDUCTION_PERCENT=$((TOTAL_SAVINGS * 100 / TOTAL_LINES))
    echo -e "  ${GREEN}코드 감소율: 약 $REDUCTION_PERCENT%${NC}"
fi

echo -e "\n${CYAN}═══════════════════════════════════════${NC}"
echo -e "${YELLOW}📋 Step 8: Flutter Analyze 결과${NC}"
echo -e "${CYAN}═══════════════════════════════════════${NC}"

# Flutter analyze 실행
echo -e "\n분석 중..."
ANALYZE_OUTPUT=$(flutter analyze --no-pub 2>&1)
ERROR_COUNT=$(echo "$ANALYZE_OUTPUT" | grep -c "error" || true)
WARNING_COUNT=$(echo "$ANALYZE_OUTPUT" | grep -c "warning" || true)
INFO_COUNT=$(echo "$ANALYZE_OUTPUT" | grep -c "info" || true)

echo -e "Flutter Analyze 결과:"
echo -e "  • 에러: ${RED}$ERROR_COUNT${NC}개"
echo -e "  • 경고: ${YELLOW}$WARNING_COUNT${NC}개"
echo -e "  • 정보: ${BLUE}$INFO_COUNT${NC}개"

echo -e "\n${CYAN}═══════════════════════════════════════${NC}"
echo -e "${YELLOW}📋 Step 9: 주요 중복 파일 분석${NC}"
echo -e "${CYAN}═══════════════════════════════════════${NC}"

echo -e "\n${GREEN}main_screen.dart 분석:${NC}"
if [ -f "lib/presentation/screens/main/main_screen.dart" ]; then
    MAIN_LINES=$(wc -l < "lib/presentation/screens/main/main_screen.dart")
    MAIN_DIALOGS=$(grep -c "showDialog\|AlertDialog" "lib/presentation/screens/main/main_screen.dart" || true)
    MAIN_IMPORTS=$(grep -c "^import " "lib/presentation/screens/main/main_screen.dart" || true)
    
    echo -e "  • 전체 라인: ${RED}$MAIN_LINES${NC}줄"
    echo -e "  • Import 수: ${YELLOW}$MAIN_IMPORTS${NC}개"
    echo -e "  • Dialog 사용: ${YELLOW}$MAIN_DIALOGS${NC}회"
    echo -e "  ${RED}⚠️  파일 분할 강력 권장!${NC}"
fi

echo -e "\n${CYAN}════════════════════════════════════════${NC}"
echo -e "${GREEN}📊 중복 코드 정리 효과 분석 완료${NC}"
echo -e "${CYAN}════════════════════════════════════════${NC}"

# 최종 평가
echo -e "\n${GREEN}✅ 개선 가능 영역:${NC}"

if [ $APPLOGGER_COUNT -gt 20 ]; then
    echo "  • Import 최적화 필요 (AppLogger $APPLOGGER_COUNT회)"
fi

if [ $SHOW_DIALOG_COUNT -gt 10 ]; then
    echo "  • 다이얼로그 패턴 통합 필요 ($SHOW_DIALOG_COUNT개)"
fi

if [ $GEO_PERMISSION_COUNT -gt 5 ] || [ $FCM_PERMISSION_COUNT -gt 20 ]; then
    echo "  • 권한 관리 통합 필요 (위치 $GEO_PERMISSION_COUNT회, 알림 $FCM_PERMISSION_COUNT회)"
fi

if [ $LARGE_FILES -gt 5 ]; then
    echo "  • 큰 파일 분할 검토 ($LARGE_FILES개 파일)"
fi

if [ $MAIN_LINES -gt 1000 ]; then
    echo "  • ${RED}main_screen.dart 즉시 분할 필요!${NC}"
fi

echo -e "\n${YELLOW}💡 권장 조치:${NC}"
echo "1. ${BLUE}main_screen.dart를 기능별로 분할${NC}"
echo "   - 지도 관련 → map_widget.dart"
echo "   - 팝업 관련 → popup_manager.dart"
echo "   - 타이머 관련 → timer_handler.dart"
echo "2. ${BLUE}공통 다이얼로그 패턴 통합${NC}"
echo "3. ${BLUE}권한 관리 코드 통합${NC}"
echo "4. ${BLUE}중복 Import 정리${NC}"

echo -e "\n${GREEN}📈 예상 개선 효과:${NC}"
echo "  • 코드 가독성 향상"
echo "  • 유지보수성 개선"
echo "  • 약 $TOTAL_SAVINGS줄 코드 감소 ($REDUCTION_PERCENT%)"

echo -e "\n${GREEN}검증 완료!${NC}"
