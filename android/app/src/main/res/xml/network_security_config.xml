<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 기본은 HTTPS만 허용 -->
    <base-config cleartextTrafficPermitted="false" />

    <!-- 개발용 디버그 빌드에선 HTTP도 허용 -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
        <domain-config cleartextTrafficPermitted="true">
            <domain includeSubdomains="true">10.0.2.2</domain> <!-- 에뮬레이터 localhost -->
            <domain includeSubdomains="true">your-dev-api.com</domain>
        </domain-config>
    </debug-overrides>
</network-security-config>